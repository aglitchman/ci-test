+unzip -o $DYNAMO_HOME/ext/share/luajit-share.zip -d $DYNAMO_HOME/ext/share/
+# jar cfM lib/luajit-share.zip -C $DYNAMO_HOME/ext/share/ luajit
+
+#LIPO
+back_cp $DYNAMO_HOME/ext/bin/x86_64-macos/lipo libexec/x86_64-macos/lipo
+back_cp $DYNAMO_HOME/ext/bin/arm64-macos/lipo libexec/arm64-macos/lipo
+back_cp $DYNAMO_HOME/ext/bin/x86_64-linux/lipo libexec/x86_64-linux/lipo
+#back_cp $DYNAMO_HOME/ext/bin/arm64-linux/lipo libexec/arm64-linux/lipo
+back_cp $DYNAMO_HOME/ext/bin/x86_64-win32/lipo.exe libexec/x86_64-win32/lipo.exe
+
+copy () {
+    back_cp $DYNAMO_HOME/archive/${SHA1}/engine/$1 libexec/$2
+}
+
+copy x86_64-linux/stripped/dmengine x86_64-linux/dmengine
+copy x86_64-linux/stripped/dmengine_release x86_64-linux/dmengine_release
