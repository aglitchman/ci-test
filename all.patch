diff --git a/share/ext/astcenc/arm64-linux.cmake b/share/ext/astcenc/arm64-linux.cmake
new file mode 100644
index 0000000000..e782584d29
--- /dev/null
+++ b/share/ext/astcenc/arm64-linux.cmake
@@ -0,0 +1,7 @@
+set(CMAKE_SYSTEM_NAME    Linux)
+set(CMAKE_SYSTEM_PROCESSOR aarch64)
+set(CMAKE_C_COMPILER     "aarch64-linux-gnu-gcc")
+set(CMAKE_CXX_COMPILER   "aarch64-linux-gnu-g++")
+set(CMAKE_FIND_ROOT_PATH /usr/aarch64-linux-gnu)
+set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
+set(CPACK_DEBIAN_PACKAGE_ARCHITECTURE arm64)
diff --git a/share/ext/astcenc/build_astcenc.sh b/share/ext/astcenc/build_astcenc.sh
index bcc3917d1b..8a981fdb3e 100755
--- a/share/ext/astcenc/build_astcenc.sh
+++ b/share/ext/astcenc/build_astcenc.sh
@@ -45,6 +45,11 @@ case $PLATFORM in
         CMAKE_FLAGS="-DCMAKE_OSX_ARCHITECTURES=x86_64 ${CMAKE_FLAGS}"
         CMAKE_FLAGS="-DCMAKE_OSX_DEPLOYMENT_TARGET=${OSX_MIN_SDK_VERSION} ${CMAKE_FLAGS}"
         ;;
+    arm64-linux)
+        CMAKE_FLAGS="-DCMAKE_TOOLCHAIN_FILE=${PWD}/arm64-linux.cmake -DARCH=aarch64 -DASTCENC_ISA_NEON=ON ${CMAKE_FLAGS}"
+        # Need to setup clang on linux
+        cmi_setup_cc $PLATFORM
+        ;;
     x86_64-linux)
         # Need to setup clang on linux
         cmi_setup_cc $PLATFORM
@@ -83,6 +88,9 @@ case $PLATFORM in
     x86_64-macos)
         LIB_NAME=libastcenc-sse4.1-static.a
         ;;
+    arm64-linux)
+        LIB_NAME=libastcenc-neon-static.a
+        ;;
     x86_64-linux)
         LIB_NAME=libastcenc-native-static.a
         ;;
