+back_cp () {
+    if [[ `unzip -Z1 $DYNAMO_HOME/share/java/bob.jar | grep "$2"` ]];then
+        echo "back_cp: extracting '$2' to '$1'"
+        mkdir -p $(dirname $1)
+        unzip -p $DYNAMO_HOME/share/java/bob.jar "$2" > "$1"
+    else
+        echo "back_cp: '$2' does not exist"
+    fi
+}
